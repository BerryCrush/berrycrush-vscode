{
  "name": "BerryCrush",
  "scopeName": "source.berrycrush",
  "patterns": [
    { "include": "#comment" },
    { "include": "#parameters-block" },
    { "include": "#tags" },
    { "include": "#feature-block" },
    { "include": "#scenario-block" },
    { "include": "#outline-block" },
    { "include": "#fragment-block" },
    { "include": "#background-block" },
    { "include": "#step" },
    { "include": "#directive" },
    { "include": "#examples-block" },
    { "include": "#auto-test-directive" }
  ],
  "repository": {
    "comment": {
      "match": "^\\s*#.*$",
      "name": "comment.line.number-sign.berrycrush"
    },
    "tags": {
      "match": "@[\\w\\-]+",
      "name": "entity.name.tag.berrycrush"
    },
    "parameters-block": {
      "begin": "^(parameters):",
      "beginCaptures": {
        "1": { "name": "keyword.control.parameters.berrycrush" }
      },
      "end": "^(?=\\S)",
      "patterns": [
        { "include": "#comment" },
        { "include": "#parameter-entry" }
      ]
    },
    "parameter-entry": {
      "match": "^\\s+([\\w\\.]+):\\s*(.*)$",
      "captures": {
        "1": { "name": "variable.parameter.berrycrush" },
        "2": { "name": "string.unquoted.berrycrush" }
      }
    },
    "feature-block": {
      "match": "^(feature):\\s*(.*)$",
      "captures": {
        "1": { "name": "keyword.control.feature.berrycrush" },
        "2": { "name": "entity.name.section.feature.berrycrush" }
      }
    },
    "background-block": {
      "match": "^\\s*(background):",
      "captures": {
        "1": { "name": "keyword.control.background.berrycrush" }
      }
    },
    "scenario-block": {
      "match": "^\\s*(scenario):\\s*(.*)$",
      "captures": {
        "1": { "name": "keyword.control.scenario.berrycrush" },
        "2": { "name": "entity.name.section.scenario.berrycrush" }
      }
    },
    "outline-block": {
      "match": "^\\s*(outline):\\s*(.*)$",
      "captures": {
        "1": { "name": "keyword.control.outline.berrycrush" },
        "2": { "name": "entity.name.section.outline.berrycrush" }
      }
    },
    "fragment-block": {
      "match": "^(fragment):\\s*(.*)$",
      "captures": {
        "1": { "name": "keyword.control.fragment.berrycrush" },
        "2": { "name": "entity.name.section.fragment.berrycrush" }
      }
    },
    "step": {
      "match": "^\\s*(given|when|then|and|but):?\\s*(.*)$",
      "captures": {
        "1": { "name": "keyword.control.step.berrycrush" },
        "2": { "name": "string.unquoted.step-description.berrycrush" }
      }
    },
    "auto-test-directive": {
      "patterns": [
        { "include": "#auto-types" },
        { "include": "#excludes-directive" },
        { "include": "#test-context-variable" }
      ]
    },
    "auto-types": {
      "match": "^\\s*(auto):\\s*\\[([^\\]]+)\\]",
      "captures": {
        "1": { "name": "keyword.other.auto.berrycrush" },
        "2": { "name": "entity.name.tag.auto-types.berrycrush" }
      }
    },
    "excludes-directive": {
      "match": "^\\s*(excludes):\\s*\\[([^\\]]+)\\]",
      "captures": {
        "1": { "name": "keyword.other.excludes.berrycrush" },
        "2": { "name": "entity.name.tag.exclude-types.berrycrush" }
      }
    },
    "test-context-variable": {
      "match": "\\b(test)\\.(type|field|description|value|location)\\b",
      "name": "variable.other.test-context.berrycrush"
    },
    "directive": {
      "patterns": [
        { "include": "#call-directive" },
        { "include": "#assert-directive" },
        { "include": "#extract-directive" },
        { "include": "#include-directive" },
        { "include": "#conditional-directive" },
        { "include": "#fail-directive" },
        { "include": "#body-directive" },
        { "include": "#bodyfile-directive" },
        { "include": "#parameter-value" }
      ]
    },
    "call-directive": {
      "match": "^\\s*(call)\\s+(?:(using)\\s+(\\w+)\\s+)?\\^([\\w\\-]+)",
      "captures": {
        "1": { "name": "keyword.other.call.berrycrush" },
        "2": { "name": "keyword.other.using.berrycrush" },
        "3": { "name": "variable.other.spec-name.berrycrush" },
        "4": { "name": "entity.name.function.operation-id.berrycrush" }
      }
    },
    "assert-directive": {
      "patterns": [
        { "include": "#assert-status" },
        { "include": "#assert-header" },
        { "include": "#assert-jsonpath" },
        { "include": "#assert-body" },
        { "include": "#assert-schema" },
        { "include": "#assert-responsetime" }
      ]
    },
    "assert-status": {
      "match": "^\\s*(assert)\\s+(status(?:Code)?)\\s+(\\d+(?:xx|-\\d+)?)",
      "captures": {
        "1": { "name": "keyword.other.assert.berrycrush" },
        "2": { "name": "support.type.assertion-type.berrycrush" },
        "3": { "name": "constant.numeric.status-code.berrycrush" }
      }
    },
    "assert-header": {
      "match": "^\\s*(assert)\\s+(header)\\s+([\\w\\-]+)(?:\\s*[:=]\\s*(.*))?",
      "captures": {
        "1": { "name": "keyword.other.assert.berrycrush" },
        "2": { "name": "support.type.assertion-type.berrycrush" },
        "3": { "name": "variable.other.header-name.berrycrush" },
        "4": { "name": "string.quoted.header-value.berrycrush" }
      }
    },
    "assert-jsonpath": {
      "match": "^\\s*(assert)\\s+(\\$[\\w\\.\\[\\]\\*]+)\\s+(not\\s+)?(equals|exists|notEmpty|greaterThan|lessThan|contains|in|hasSize|size|matches|=)\\s*(.*)?",
      "captures": {
        "1": { "name": "keyword.other.assert.berrycrush" },
        "2": { "name": "variable.other.jsonpath.berrycrush" },
        "3": { "name": "keyword.operator.not.berrycrush" },
        "4": { "name": "keyword.operator.assertion.berrycrush" },
        "5": { 
          "patterns": [
            { "include": "#string-value" },
            { "include": "#variable-interpolation" },
            { "include": "#number" }
          ]
        }
      }
    },
    "assert-body": {
      "match": "^\\s*(assert)\\s+(not\\s+)?(contains)\\s+(.+)",
      "captures": {
        "1": { "name": "keyword.other.assert.berrycrush" },
        "2": { "name": "keyword.operator.not.berrycrush" },
        "3": { "name": "support.type.assertion-type.berrycrush" },
        "4": { 
          "patterns": [
            { "include": "#string-value" },
            { "include": "#variable-interpolation" }
          ]
        }
      }
    },
    "assert-schema": {
      "match": "^\\s*(assert)\\s+(schema)\\s*$",
      "captures": {
        "1": { "name": "keyword.other.assert.berrycrush" },
        "2": { "name": "support.type.assertion-type.berrycrush" }
      }
    },
    "assert-responsetime": {
      "match": "^\\s*(assert)\\s+(responseTime)\\s+(\\d+)",
      "captures": {
        "1": { "name": "keyword.other.assert.berrycrush" },
        "2": { "name": "support.type.assertion-type.berrycrush" },
        "3": { "name": "constant.numeric.berrycrush" }
      }
    },
    "extract-directive": {
      "match": "^\\s*(extract)\\s+(\\$[\\w\\.\\[\\]\\*]+)\\s+(=>)\\s+(\\w+)",
      "captures": {
        "1": { "name": "keyword.other.extract.berrycrush" },
        "2": { "name": "variable.other.jsonpath.berrycrush" },
        "3": { "name": "keyword.operator.arrow.berrycrush" },
        "4": { "name": "variable.other.extraction-name.berrycrush" }
      }
    },
    "include-directive": {
      "match": "^\\s*(include)\\s+([\\w\\-]+)",
      "captures": {
        "1": { "name": "keyword.other.include.berrycrush" },
        "2": { "name": "entity.name.function.fragment-name.berrycrush" }
      }
    },
    "conditional-directive": {
      "patterns": [
        { "include": "#if-compound" },
        { "include": "#if-status" },
        { "include": "#if-jsonpath" },
        { "include": "#if-header" },
        { "include": "#if-test-type" },
        { "include": "#else-if" },
        { "include": "#else" }
      ]
    },
    "if-compound": {
      "match": "^\\s*(if)\\s+(.+?)\\s+(and|or)\\s+(.+)$",
      "captures": {
        "1": { "name": "keyword.control.if.berrycrush" },
        "2": { 
          "patterns": [
            { "include": "#test-context-variable" },
            { "include": "#condition-expression" }
          ]
        },
        "3": { "name": "keyword.operator.logical.berrycrush" },
        "4": { 
          "patterns": [
            { "include": "#test-context-variable" },
            { "include": "#condition-expression" }
          ]
        }
      }
    },
    "condition-expression": {
      "patterns": [
        {
          "match": "(status(?:Code)?)\\s+(\\d+(?:xx|-\\d+)?)",
          "captures": {
            "1": { "name": "support.type.condition-type.berrycrush" },
            "2": { "name": "constant.numeric.status-code.berrycrush" }
          }
        },
        {
          "match": "(test)\\.(type|field|description|value|location)\\s+(equals|notEquals|contains)\\s+(.+)",
          "captures": {
            "1": { "name": "variable.other.test-context.berrycrush" },
            "2": { "name": "variable.other.test-property.berrycrush" },
            "3": { "name": "keyword.operator.condition.berrycrush" },
            "4": { "name": "string.unquoted.berrycrush" }
          }
        }
      ]
    },
    "if-test-type": {
      "match": "^\\s*(if)\\s+(test)\\.(type|field|description|value|location)\\s+(equals|notEquals|contains)\\s+(\"[^\"]+\"|\\w+)",
      "captures": {
        "1": { "name": "keyword.control.if.berrycrush" },
        "2": { "name": "variable.other.test-context.berrycrush" },
        "3": { "name": "variable.other.test-property.berrycrush" },
        "4": { "name": "keyword.operator.condition.berrycrush" },
        "5": { 
          "patterns": [
            { "include": "#string-value" }
          ]
        }
      }
    },
    "if-status": {
      "match": "^\\s*(if)\\s+(status(?:Code)?)\\s+(\\d+(?:xx|-\\d+)?)",
      "captures": {
        "1": { "name": "keyword.control.if.berrycrush" },
        "2": { "name": "support.type.condition-type.berrycrush" },
        "3": { "name": "constant.numeric.status-code.berrycrush" }
      }
    },
    "if-jsonpath": {
      "match": "^\\s*(if)\\s+(\\$[\\w\\.\\[\\]\\*]+)\\s+(equals|notEquals|contains|notContains|matches|exists|notExists|greaterThan|lessThan)\\s*(.*)?",
      "captures": {
        "1": { "name": "keyword.control.if.berrycrush" },
        "2": { "name": "variable.other.jsonpath.berrycrush" },
        "3": { "name": "keyword.operator.condition.berrycrush" },
        "4": { 
          "patterns": [
            { "include": "#string-value" },
            { "include": "#variable-interpolation" },
            { "include": "#number" }
          ]
        }
      }
    },
    "if-header": {
      "match": "^\\s*(if)\\s+(header)\\s+([\\w\\-]+)(?:\\s+(equals|notEquals|contains|notContains|exists|notExists)\\s*(.*))?",
      "captures": {
        "1": { "name": "keyword.control.if.berrycrush" },
        "2": { "name": "support.type.condition-type.berrycrush" },
        "3": { "name": "variable.other.header-name.berrycrush" },
        "4": { "name": "keyword.operator.condition.berrycrush" },
        "5": { 
          "patterns": [
            { "include": "#string-value" },
            { "include": "#variable-interpolation" }
          ]
        }
      }
    },
    "else-if": {
      "match": "^\\s*(else)\\s+(if)\\b",
      "captures": {
        "1": { "name": "keyword.control.else.berrycrush" },
        "2": { "name": "keyword.control.if.berrycrush" }
      }
    },
    "else": {
      "match": "^\\s*(else)\\s*$",
      "captures": {
        "1": { "name": "keyword.control.else.berrycrush" }
      }
    },
    "fail-directive": {
      "match": "^\\s*(fail)\\s+(.+)$",
      "captures": {
        "1": { "name": "keyword.other.fail.berrycrush" },
        "2": { "name": "string.unquoted.error-message.berrycrush" }
      }
    },
    "body-directive": {
      "begin": "^\\s*(body):\\s*(?:(>)\\s*)?",
      "beginCaptures": {
        "1": { "name": "keyword.other.body.berrycrush" },
        "2": { "name": "keyword.operator.multiline.berrycrush" }
      },
      "end": "$",
      "patterns": [
        { "include": "#json-body" },
        { "include": "#variable-interpolation" }
      ]
    },
    "bodyfile-directive": {
      "match": "^\\s*(bodyFile):\\s*(.+)",
      "captures": {
        "1": { "name": "keyword.other.bodyfile.berrycrush" },
        "2": { "name": "string.unquoted.filepath.berrycrush" }
      }
    },
    "parameter-value": {
      "match": "^\\s+(header_)?([\\w\\-]+):\\s*(.*)$",
      "captures": {
        "1": { "name": "support.type.header-prefix.berrycrush" },
        "2": { "name": "variable.parameter.berrycrush" },
        "3": {
          "patterns": [
            { "include": "#string-value" },
            { "include": "#variable-interpolation" },
            { "include": "#number" },
            { "include": "#boolean" }
          ]
        }
      }
    },
    "examples-block": {
      "begin": "^\\s*(examples):",
      "beginCaptures": {
        "1": { "name": "keyword.control.examples.berrycrush" }
      },
      "end": "^(?=\\S)",
      "patterns": [
        { "include": "#table-row" }
      ]
    },
    "table-row": {
      "match": "^\\s*\\|(.*)\\|\\s*$",
      "captures": {
        "1": { "name": "string.unquoted.table-cell.berrycrush" }
      }
    },
    "variable-interpolation": {
      "patterns": [
        {
          "match": "\\{\\{([\\w\\.\\-]+)\\}\\}",
          "name": "variable.other.interpolation.berrycrush",
          "captures": {
            "1": { "name": "variable.other.name.berrycrush" }
          }
        },
        {
          "match": "\\$\\{([\\w\\.\\-]+)\\}",
          "name": "variable.other.interpolation.berrycrush",
          "captures": {
            "1": { "name": "variable.other.name.berrycrush" }
          }
        },
        {
          "match": "\\$([a-zA-Z_][\\w]*)",
          "name": "variable.other.interpolation.berrycrush",
          "captures": {
            "1": { "name": "variable.other.name.berrycrush" }
          }
        }
      ]
    },
    "string-value": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.berrycrush",
          "patterns": [
            { "include": "#variable-interpolation" },
            { "match": "\\\\.", "name": "constant.character.escape.berrycrush" }
          ]
        },
        {
          "begin": "'",
          "end": "'",
          "name": "string.quoted.single.berrycrush",
          "patterns": [
            { "include": "#variable-interpolation" }
          ]
        }
      ]
    },
    "json-body": {
      "begin": "\\{",
      "end": "\\}",
      "name": "meta.structure.json.berrycrush",
      "patterns": [
        { "include": "#variable-interpolation" },
        { "include": "#string-value" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#json-body" },
        { "include": "#json-array" }
      ]
    },
    "json-array": {
      "begin": "\\[",
      "end": "\\]",
      "name": "meta.structure.array.berrycrush",
      "patterns": [
        { "include": "#variable-interpolation" },
        { "include": "#string-value" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#json-body" },
        { "include": "#json-array" }
      ]
    },
    "number": {
      "match": "-?\\d+(\\.\\d+)?",
      "name": "constant.numeric.berrycrush"
    },
    "boolean": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.berrycrush"
    }
  }
}
