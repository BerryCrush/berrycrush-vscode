@api @smoke feature: Pet Store API Tests
  # Background runs before each scenario
  background:
    given authenticated user
      include auth
  
  scenario: List all pets
    when listing pets
      call ^listPets
    then pets are returned
      assert status 200
      assert $.data notEmpty
      extract $.data[0].id => firstPetId
  
  @critical scenario: Get pet by ID
    given I have a pet ID
      call using petstore ^listPets
      extract $.data[0].id => petId
    when requesting pet
      call ^getPetById
        petId: {{petId}}
    then pet details returned
      assert status 200
      assert $.name exists
      assert $.status in ["available", "pending", "sold"]

  scenario: Create pet with body
    when creating a pet
      call ^createPet
        body:
          """
          {
            "name": "Fluffy",
            "status": "available",
            "tags": ["cute"]
          }
          """
    then pet is created
      assert status 201
      extract $.id => newPetId

  scenario: Update pet status
    given existing pet
      include auth
      call ^listPets
      extract $.data[0].id => existingPetId
    when updating pet
      call ^updatePet
        petId: {{existingPetId}}
        body:
          status: sold
    then pet is updated
      assert status 200

outline: Create pets with different statuses
  when creating pet with status <status>
    call ^createPet
      body:
        name: <name>
        status: <status>
  then pet created successfully
    assert status 201
  examples:
    | name     | status    |
    | Fluffy   | available |
    | Max      | pending   |
    | Whiskers | sold      |

# Standalone scenario (no feature)
scenario: Standalone health check
  when checking health
    call ^healthCheck
  then system is healthy
    assert status 200
    assert $.status equals "UP"
