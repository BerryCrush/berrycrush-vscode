{
  "name": "berrycrush",
  "displayName": "BerryCrush",
  "description": "IDE support for BerryCrush scenario files - syntax highlighting, completion, and navigation",
  "version": "1.0.0",
  "publisher": "berrycrush",
  "license": "Apache-2.0",
  "icon": "resources/berrycrush.svg",
  "repository": {
    "type": "git",
    "url": "https://github.com/BerryCrush/berrycrush-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Testing"
  ],
  "keywords": [
    "berrycrush",
    "openapi",
    "api",
    "testing",
    "bdd"
  ],
  "activationEvents": [
    "onLanguage:berrycrush"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "berrycrush-scenario",
        "aliases": ["BerryCrush Scenario"],
        "extensions": [".scenario"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./resources/icons/scenario-icon.svg",
          "dark": "./resources/icons/scenario-icon.svg"
        }
      },
      {
        "id": "berrycrush-fragment",
        "aliases": ["BerryCrush Fragment"],
        "extensions": [".fragment"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./resources/icons/fragment-icon.svg",
          "dark": "./resources/icons/fragment-icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "berrycrush-scenario",
        "scopeName": "source.berrycrush",
        "path": "./syntaxes/berrycrush.tmLanguage.json"
      },
      {
        "language": "berrycrush-fragment",
        "scopeName": "source.berrycrush",
        "path": "./syntaxes/berrycrush.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "berrycrush-scenario",
        "path": "./snippets/berrycrush.code-snippets"
      },
      {
        "language": "berrycrush-fragment",
        "path": "./snippets/berrycrush.code-snippets"
      }
    ],
    "configuration": {
      "title": "BerryCrush",
      "properties": {
        "berrycrush.openapi.path": {
          "type": "string",
          "default": "",
          "description": "Path to OpenAPI spec file (relative to workspace root)"
        },
        "berrycrush.openapi.paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Paths to OpenAPI spec files for multi-spec projects"
        },
        "berrycrush.fragmentsPath": {
          "type": "string",
          "default": "src/test/resources",
          "description": "Path to search for fragment files"
        },
        "berrycrush.formatting.indentSize": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 8,
          "description": "Number of spaces per indentation level"
        },
        "berrycrush.formatting.alignTables": {
          "type": "boolean",
          "default": true,
          "description": "Align columns in examples tables"
        }
      }
    },
    "commands": [
      {
        "command": "berrycrush.refreshOpenApi",
        "title": "BerryCrush: Refresh OpenAPI"
      },
      {
        "command": "berrycrush.refreshFragments",
        "title": "BerryCrush: Refresh Fragments"
      },
      {
        "command": "berrycrush.refreshSteps",
        "title": "BerryCrush: Refresh Custom Steps"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "9.26.0",
    "glob": "11.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.3.3",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "yaml": "^2.3.4"
  }
}
